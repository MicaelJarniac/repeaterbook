{
  "$defs": {
    "RepeaterMode": {
      "description": "A single radio operating mode for one programmable channel.",
      "enum": [
        "FM",
        "DMR",
        "DSTAR",
        "FUSION",
        "P25",
        "NXDN",
        "TETRA",
        "M17"
      ],
      "title": "RepeaterMode",
      "type": "string"
    }
  },
  "description": "One programmable radio channel, derived from a repeater.\n\nCarries absolute rx/tx frequencies so the consuming radio owns the\nduplex/offset derivation. Multi-mode repeaters expand to one intent per mode.",
  "properties": {
    "name": {
      "title": "Name",
      "type": "string"
    },
    "callsign": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "title": "Callsign"
    },
    "rx_frequency_mhz": {
      "anyOf": [
        {
          "type": "number"
        },
        {
          "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
          "type": "string"
        }
      ],
      "title": "Rx Frequency Mhz"
    },
    "tx_frequency_mhz": {
      "anyOf": [
        {
          "type": "number"
        },
        {
          "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
          "type": "string"
        }
      ],
      "title": "Tx Frequency Mhz"
    },
    "mode": {
      "$ref": "#/$defs/RepeaterMode"
    },
    "ctcss_tx_hz": {
      "anyOf": [
        {
          "type": "number"
        },
        {
          "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "title": "Ctcss Tx Hz"
    },
    "ctcss_rx_hz": {
      "anyOf": [
        {
          "type": "number"
        },
        {
          "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "title": "Ctcss Rx Hz"
    },
    "dcs_code": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "title": "Dcs Code"
    },
    "latitude": {
      "anyOf": [
        {
          "type": "number"
        },
        {
          "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
          "type": "string"
        }
      ],
      "title": "Latitude"
    },
    "longitude": {
      "anyOf": [
        {
          "type": "number"
        },
        {
          "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
          "type": "string"
        }
      ],
      "title": "Longitude"
    },
    "distance_km": {
      "anyOf": [
        {
          "type": "number"
        },
        {
          "type": "null"
        }
      ],
      "title": "Distance Km"
    },
    "operational_status": {
      "title": "Operational Status",
      "type": "string"
    },
    "use": {
      "title": "Use",
      "type": "string"
    },
    "band": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "title": "Band"
    },
    "notes": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "title": "Notes"
    },
    "last_update": {
      "format": "date",
      "title": "Last Update",
      "type": "string"
    },
    "source": {
      "default": "repeaterbook",
      "title": "Source",
      "type": "string"
    },
    "source_id": {
      "title": "Source Id",
      "type": "string"
    }
  },
  "required": [
    "name",
    "callsign",
    "rx_frequency_mhz",
    "tx_frequency_mhz",
    "mode",
    "ctcss_tx_hz",
    "ctcss_rx_hz",
    "dcs_code",
    "latitude",
    "longitude",
    "distance_km",
    "operational_status",
    "use",
    "band",
    "notes",
    "last_update",
    "source_id"
  ],
  "title": "RepeaterSpec",
  "type": "object"
}
